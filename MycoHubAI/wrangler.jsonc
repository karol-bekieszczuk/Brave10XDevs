{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "myco-hub-ai",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-05-08",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page",
  },
  "observability": {
    "enabled": true,
  },
  "secrets": {
    "required": ["SUPABASE_URL", "SUPABASE_KEY", "AUTHORIZED_USER_ID", "OPENAI_API_KEY"],
  },
}
