---
import GrowLogCard from "@/components/grow-logs/GrowLogCard.astro";
import Layout from "@/layouts/Layout.astro";
import { listOwnerGrowLogs } from "@/lib/grow-logs/repository";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const logs = user && supabase ? await listOwnerGrowLogs(supabase, user.id) : [];
const error = Astro.url.searchParams.get("error");
const message = Astro.url.searchParams.get("message");
---

<Layout title="Grow logs">
  <div class="bg-cosmic min-h-screen px-4 py-10 text-white">
    <div class="mx-auto max-w-5xl">
      <div
        class="flex flex-col gap-6 rounded-[2rem] border border-white/10 bg-slate-950/35 p-6 shadow-2xl shadow-cyan-950/20 backdrop-blur sm:flex-row sm:items-end sm:justify-between"
      >
        <div class="max-w-2xl">
          <p class="text-sm tracking-[0.35em] text-cyan-200/80 uppercase">Private grow logs</p>
          <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white">
            Track agar and grain work without leaving the MVP scope.
          </h1>
          <p class="mt-3 text-base leading-7 text-blue-100/75">
            Each entry stays owner-scoped and text-only so the later diagnosis slice can attach to a real single-log
            detail page.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href="/dashboard"
            class="inline-flex items-center rounded-full border border-white/15 px-5 py-3 text-sm font-medium text-white/80 transition hover:border-white/30 hover:text-white"
          >
            Back to dashboard
          </a>
          <a
            href="/grow-logs/new"
            class="inline-flex items-center rounded-full bg-cyan-300 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200"
          >
            New grow log
          </a>
        </div>
      </div>

      {
        message && (
          <div class="mt-6 rounded-2xl border border-emerald-400/40 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
            {message}
          </div>
        )
      }

      {
        error && (
          <div class="mt-6 rounded-2xl border border-amber-400/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
            {error}
          </div>
        )
      }

      {
        !user || !supabase ? (
          <div class="mt-8 rounded-[2rem] border border-white/10 bg-white/6 p-10 text-center">
            <h2 class="text-2xl font-semibold text-white">Grow logs are unavailable right now.</h2>
            <p class="mt-3 text-blue-100/70">
              The authenticated session or Supabase client could not be loaded for this request.
            </p>
          </div>
        ) : logs.length === 0 ? (
          <div class="mt-8 rounded-[2rem] border border-dashed border-white/15 bg-white/6 p-10 text-center">
            <h2 class="text-2xl font-semibold text-white">No grow logs yet.</h2>
            <p class="mt-3 text-blue-100/70">
              Start with an agar plate or a grain jar entry so later diagnosis work has a real log to target.
            </p>
            <a
              href="/grow-logs/new"
              class="mt-6 inline-flex items-center rounded-full bg-cyan-300 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200"
            >
              Create your first log
            </a>
          </div>
        ) : (
          <form
            class="mt-8 grid gap-5"
            method="POST"
            action="/api/grow-logs/bulk-delete"
            onsubmit={
              "const count = this.querySelectorAll('input[name=\"selectedLogIds\"]:checked').length; if (count === 0) { window.alert('Select at least one grow log.'); return false; } return window.confirm('Delete ' + count + ' selected grow log' + (count === 1 ? '' : 's') + ' permanently? This cannot be undone.');"
            }
          >
            <div class="flex flex-col gap-3 rounded-3xl border border-red-400/20 bg-red-500/5 p-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="text-sm font-semibold text-white">Bulk delete</p>
                <p class="mt-1 text-sm text-blue-100/75">Select grow logs to delete them permanently.</p>
              </div>
              <button
                type="submit"
                class="inline-flex items-center justify-center rounded-full border border-red-400/40 bg-red-500/10 px-5 py-3 text-sm font-semibold text-red-100 transition hover:border-red-300/70 hover:bg-red-500/20"
              >
                Delete selected
              </button>
            </div>

            {logs.map((log) => (
              <GrowLogCard log={log} />
            ))}
          </form>
        )
      }
    </div>
  </div>
</Layout>
