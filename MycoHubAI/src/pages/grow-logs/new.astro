---
import GrowLogForm from "@/components/grow-logs/GrowLogForm.astro";
import Layout from "@/layouts/Layout.astro";
import type { GrowLogStage } from "@/lib/grow-logs/types";
import { isGrowLogStage } from "@/lib/grow-logs/types";

const stageParam = Astro.url.searchParams.get("stage");
const stage: GrowLogStage = isGrowLogStage(stageParam) ? stageParam : "agar";
const error = Astro.url.searchParams.get("error");
---

<Layout title="New grow log">
  <div class="bg-cosmic min-h-screen px-4 py-10 text-white">
    <div class="mx-auto max-w-3xl">
      <div
        class="rounded-[2rem] border border-white/10 bg-slate-950/35 p-6 shadow-2xl shadow-cyan-950/20 backdrop-blur"
      >
        <p class="text-sm tracking-[0.35em] text-cyan-200/80 uppercase">New entry</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white">Capture one staged text log.</h1>
        <p class="mt-3 text-base leading-7 text-blue-100/75">
          This form only accepts the current MVP contract: `agar` or `grain`, plus a title and body.
        </p>

        <div class="mt-8">
          <GrowLogForm
            action="/api/grow-logs/create"
            cancelHref="/grow-logs"
            error={error}
            stage={stage}
            title=""
            body=""
            submitLabel="Create grow log"
          />
        </div>
      </div>
    </div>
  </div>
</Layout>
