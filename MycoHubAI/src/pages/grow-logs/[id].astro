---
import Layout from "@/layouts/Layout.astro";
import SelectedLogDiagnosisPanel from "@/components/diagnosis/SelectedLogDiagnosisPanel";
import { getOwnerGrowLog } from "@/lib/grow-logs/repository";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const log = user && supabase ? await getOwnerGrowLog(supabase, Astro.params.id ?? "", user.id) : null;
const isUnavailable = !user || !supabase;

if (!log && !isUnavailable) {
  Astro.response.status = 404;
}

const error = Astro.url.searchParams.get("error");
const createdAt = log
  ? new Date(log.createdAt).toLocaleString("en-US", {
      dateStyle: "medium",
      timeStyle: "short",
    })
  : "";
const updatedAt = log
  ? new Date(log.updatedAt).toLocaleString("en-US", {
      dateStyle: "medium",
      timeStyle: "short",
    })
  : "";
---

<Layout title={log ? log.title : "Grow log not found"}>
  <div class="bg-cosmic min-h-screen px-4 py-10 text-white">
    <div class="mx-auto max-w-3xl">
      {
        !log ? (
          <div class="rounded-[2rem] border border-white/10 bg-slate-950/35 p-8 text-center shadow-2xl shadow-cyan-950/20 backdrop-blur">
            <p class="text-sm tracking-[0.35em] text-cyan-200/80 uppercase">
              {isUnavailable ? "Unavailable" : "Not found"}
            </p>
            <h1 class="mt-3 text-3xl font-semibold text-white">
              {isUnavailable
                ? "This request could not load the private grow-log client."
                : "That grow log is missing or not available to this owner."}
            </h1>
            <p class="mt-3 text-blue-100/75">
              {isUnavailable
                ? "Refresh the session and try again."
                : "No row contents were loaded. Return to your private list and choose another entry."}
            </p>
            <a
              href="/grow-logs"
              class="mt-6 inline-flex items-center rounded-full bg-cyan-300 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200"
            >
              Back to grow logs
            </a>
          </div>
        ) : (
          <div class="rounded-[2rem] border border-white/10 bg-slate-950/35 p-6 shadow-2xl shadow-cyan-950/20 backdrop-blur">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-sm tracking-[0.35em] text-cyan-200/80 uppercase">{log.stage}</p>
                <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white">{log.title}</h1>
              </div>
              <div class="flex flex-wrap gap-3">
                <a
                  href="/grow-logs"
                  class="inline-flex items-center rounded-full border border-white/15 px-5 py-3 text-sm font-medium text-white/80 transition hover:border-white/30 hover:text-white"
                >
                  Back to list
                </a>
                <a
                  href={`/grow-logs/${log.id}/edit`}
                  class="inline-flex items-center rounded-full bg-cyan-300 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200"
                >
                  Edit log
                </a>
              </div>
            </div>

            {error && (
              <div class="mt-6 rounded-2xl border border-amber-400/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
                {error}
              </div>
            )}

            <div class="mt-8 grid gap-4 rounded-3xl border border-white/10 bg-white/8 p-5 text-sm text-blue-100/75 sm:grid-cols-2">
              <div>
                <p class="font-medium text-white">Created</p>
                <p class="mt-1">{createdAt}</p>
              </div>
              <div>
                <p class="font-medium text-white">Updated</p>
                <p class="mt-1">{updatedAt}</p>
              </div>
            </div>

            <article class="mt-6 rounded-3xl border border-white/10 bg-white/8 p-6">
              <h2 class="text-sm font-semibold tracking-[0.3em] text-cyan-200 uppercase">Body</h2>
              <p class="mt-4 text-base leading-7 whitespace-pre-wrap text-blue-100/85">{log.body}</p>
            </article>

            <SelectedLogDiagnosisPanel client:load growLogId={log.id} logTitle={log.title} logStage={log.stage} />

            <form
              action={`/api/grow-logs/${log.id}/delete`}
              method="POST"
              class="mt-6"
              onsubmit="return confirm('Delete this grow log permanently? This cannot be undone.');"
            >
              <button
                type="submit"
                class="inline-flex items-center rounded-full border border-red-400/40 bg-red-500/10 px-5 py-3 text-sm font-semibold text-red-100 transition hover:border-red-300/70 hover:bg-red-500/20"
              >
                Delete permanently
              </button>
            </form>
          </div>
        )
      }
    </div>
  </div>
</Layout>
