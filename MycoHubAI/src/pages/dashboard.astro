---
import Layout from "@/layouts/Layout.astro";

const { user } = Astro.locals;
const error = Astro.url.searchParams.get("error");
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen px-4 py-10 text-white">
    <div
      class="mx-auto max-w-5xl rounded-[2rem] border border-white/10 bg-slate-950/35 p-6 shadow-2xl shadow-cyan-950/20 backdrop-blur"
    >
      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm tracking-[0.35em] text-cyan-200/80 uppercase">Owner dashboard</p>
          <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white">Your private mushroom workbench.</h1>
          <p class="mt-3 text-base leading-7 text-blue-100/75">
            Welcome, <span class="font-semibold text-white">{user?.email}</span>. Manage staged text grow logs here,
            then feed a real entry into diagnosis in the next slice.
          </p>
        </div>

        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="rounded-full border border-white/20 bg-white/10 px-5 py-3 text-sm font-medium transition-colors hover:bg-white/20"
          >
            Sign out
          </button>
        </form>
      </div>

      <div class="mt-8 grid gap-5 lg:grid-cols-[1.3fr_0.9fr]">
        <a
          href="/grow-logs"
          class="group rounded-[2rem] border border-cyan-300/15 bg-linear-to-br from-cyan-300/20 via-sky-400/10 to-slate-950/30 p-6 transition hover:border-cyan-200/45 hover:from-cyan-300/25 hover:via-sky-400/15"
        >
          <p class="text-sm tracking-[0.3em] text-cyan-100/80 uppercase">Grow logs</p>
          <h2 class="mt-3 text-3xl font-semibold text-white">Open the staged CRUD workspace.</h2>
          <p class="mt-3 max-w-xl text-base leading-7 text-blue-100/75">
            Create, inspect, edit, and hard-delete private `agar` and `grain` entries without expanding the product
            beyond the MVP contract.
          </p>
          <span
            class="mt-6 inline-flex items-center text-sm font-semibold text-cyan-100 transition group-hover:text-white"
          >
            Go to /grow-logs
          </span>
        </a>

        <div class="rounded-[2rem] border border-white/10 bg-white/8 p-6">
          <p class="text-sm tracking-[0.3em] text-cyan-200/80 uppercase">Current boundary</p>
          <ul class="mt-4 space-y-3 text-sm leading-6 text-blue-100/75">
            <li>Only `agar` and `grain` stages are supported.</li>
            <li>Logs remain private and owner-scoped.</li>
            <li>No diagnosis history, images, sharing, or export in this slice.</li>
          </ul>
        </div>
      </div>

      <section class="mt-8 rounded-[2rem] border border-red-400/20 bg-red-950/20 p-6">
        <p class="text-sm tracking-[0.3em] text-red-200/80 uppercase">Danger zone</p>
        <h2 class="mt-3 text-2xl font-semibold text-white">Request account deletion</h2>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-red-100/80">
          This disables your account immediately. Your account and related grow logs are permanently deleted after 30
          days.
        </p>

        {
          error && (
            <p class="mt-4 rounded-2xl border border-red-400/30 bg-red-900/30 px-4 py-3 text-sm text-red-100">
              {error}
            </p>
          )
        }

        <form
          method="POST"
          action="/api/account/delete"
          class="mt-5"
          onsubmit="return window.confirm('Your account will be disabled now and permanently deleted after 30 days. Continue?');"
        >
          <button
            type="submit"
            class="rounded-full border border-red-300/30 bg-red-500/15 px-5 py-3 text-sm font-medium text-red-50 transition-colors hover:bg-red-500/25"
          >
            Delete account
          </button>
        </form>
      </section>
    </div>
  </div>
</Layout>
