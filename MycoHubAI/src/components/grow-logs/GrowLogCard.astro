---
import type { GrowLogRow } from "@/lib/grow-logs/types";

interface Props {
  log: GrowLogRow;
}

const { log } = Astro.props;
const preview = log.body.length > 160 ? `${log.body.slice(0, 157)}...` : log.body;
const updatedAt = new Date(log.updatedAt).toLocaleString("en-US", {
  dateStyle: "medium",
  timeStyle: "short",
});
---

<article class="rounded-3xl border border-white/10 bg-white/8 p-5 backdrop-blur-xl">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold tracking-[0.3em] text-cyan-200 uppercase">{log.stage}</p>
      <h2 class="mt-2 text-xl font-semibold text-white">{log.title}</h2>
    </div>
    <a
      href={`/grow-logs/${log.id}`}
      class="inline-flex shrink-0 items-center rounded-full border border-cyan-300/30 px-3 py-1 text-xs font-medium text-cyan-100 transition hover:border-cyan-200/60 hover:text-white"
    >
      Open
    </a>
  </div>

  <p class="mt-4 text-sm leading-6 text-blue-100/80">{preview}</p>

  <div
    class="mt-5 flex flex-col gap-3 border-t border-white/10 pt-4 text-sm text-blue-100/70 sm:flex-row sm:items-center sm:justify-between"
  >
    <span>Updated {updatedAt}</span>
    <div class="flex gap-3">
      <a href={`/grow-logs/${log.id}`} class="text-cyan-200 transition hover:text-cyan-100">View</a>
      <a href={`/grow-logs/${log.id}/edit`} class="text-cyan-200 transition hover:text-cyan-100">Edit</a>
    </div>
  </div>
</article>
